<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/16" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="plugin.javafxtools.controller.MemoReminderController"
      spacing="12" styleClass="tool-page">
    <padding>
        <Insets top="10" right="10" bottom="10" left="10"/>
    </padding>

    <Label text="备忘提醒配置" styleClass="page-title"/>
    <GridPane hgap="10" vgap="10" styleClass="toolbar-card">
        <columnConstraints>
            <ColumnConstraints percentWidth="12"/>
            <ColumnConstraints percentWidth="38"/>
            <ColumnConstraints percentWidth="10"/>
            <ColumnConstraints percentWidth="15"/>
            <ColumnConstraints percentWidth="10"/>
            <ColumnConstraints percentWidth="15"/>
        </columnConstraints>

        <Label text="备忘内容:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
        <TextArea fx:id="memoInput" prefRowCount="2" promptText="例如：18:00 提醒提交日报" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

        <Label text="间隔:" GridPane.rowIndex="0" GridPane.columnIndex="2"/>
        <TextField fx:id="intervalField" text="30" promptText="数字" GridPane.rowIndex="0" GridPane.columnIndex="3"/>

        <Label text="单位:" GridPane.rowIndex="0" GridPane.columnIndex="4"/>
        <ComboBox fx:id="intervalUnitBox" GridPane.rowIndex="0" GridPane.columnIndex="5"/>

        <Label text="提醒次数(&lt;=0无限):" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
        <TextField fx:id="timesField" text="1" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

        <HBox spacing="8" GridPane.rowIndex="1" GridPane.columnIndex="3" GridPane.columnSpan="3">
            <Button text="新增提醒" onAction="#addReminder" styleClass="success-button"/>
            <Button text="暂停选中" onAction="#pauseSelected" styleClass="secondary-button"/>
            <Button text="恢复选中" onAction="#resumeSelected" styleClass="secondary-button"/>
            <Button text="删除选中" onAction="#removeSelected" styleClass="danger-button"/>
        </HBox>
    </GridPane>

    <TableView fx:id="reminderTable" VBox.vgrow="ALWAYS" styleClass="content-card">
        <columns>
            <TableColumn fx:id="contentCol" text="内容" prefWidth="320"/>
            <TableColumn fx:id="intervalCol" text="周期" prefWidth="120"/>
            <TableColumn fx:id="remainCol" text="剩余次数" prefWidth="100"/>
            <TableColumn fx:id="nextTimeCol" text="下次提醒" prefWidth="200"/>
            <TableColumn fx:id="statusCol" text="状态" prefWidth="100"/>
        </columns>
    </TableView>

    <VBox spacing="8" styleClass="log-panel">
        <Label text="模块日志" styleClass="section-title"/>
        <TextArea fx:id="logArea" prefRowCount="8" editable="false" styleClass="log-area"/>
    </VBox>
</VBox>
